          "provider": "huggingface",
          "repo": "Kwai-Kolors/Kolors-diffusers",
          "files": [],
          "estimatedSizeBytes": 17716740096
        }
      ],
      "paths": {
        "model": "${HF_CACHE}/Kwai-Kolors/Kolors-diffusers"
