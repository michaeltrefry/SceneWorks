        "samplers": ["default", "euler", "euler_ancestral", "heun", "dpmpp_2m", "dpmpp_sde", "uni_pc", "lcm", "ddim"]
      },
      "loraCompatibility": {
        "families": ["ltx-video"],
        "types": ["style", "motion", "character", "enhance"]
      },
      "mlx": {
        // Turnkey pre-converted MLX bundle on the SceneWorks HF org (sc-5608, epic 5594) —
        // replaces the third-party notapalindrome (LTX) + mlx-community (gemma) mirrors. One repo
        // with `q4/` (default) + `q8/` (opt-in via advanced mlxQuantize: 8) LTX subdirs and the
        // bundled `gemma/` text encoder. The worker (resolve_ltx_model_dir, video_jobs.rs) picks the
        // quant subdir and points the engine at the bundled gemma via $LTX_GEMMA_DIR, so a fresh
        // install needs no separate gemma snapshot. Downloaded on first use (the macOS entry in
        // downloads above); no in-app conversion. Dual-licensed (LTX-2 Community License + Google
        // Gemma Terms — distributed under those, not Apache). minMemoryGb mirrors MlxVideoAdapter
        // estimate_requirements peak_gb (the weights are pre-quantized, so no bf16 load transient).
        "minMemoryGb": 31,
        "repo": "SceneWorks/ltx-2.3-mlx"
      },
      "ui": {
        "label": "LTX-2.3",
        "description": "First-class short-shot video target for image-to-video and text-to-video.",
        "recommendedFor": ["image_to_video", "text_to_video", "first_last_frame", "extend_clip", "video_bridge"],
        "durationHint": "Best for short clips. Start with 4-8 seconds; 10 seconds is the normal ceiling for the current workflow.",
        "promptGuide": {
