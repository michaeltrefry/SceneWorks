{
  "name": "sceneworks",
  "private": true,
  "version": "0.1.0",
  "description": "Local AI image and video generation studio runtime skeleton.",
  "scripts": {
    "dev": "docker compose up --build",
    "stack:up": "docker compose up --build",
    "stack:down": "docker compose down",
    "check": "node scripts/check-scaffold.mjs",
    "check:health": "node scripts/check-health.mjs",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:lint": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:test": "cargo test --workspace",
    "rust:test:python-live": "cargo test -p sceneworks-core --features python-live --test python_live_contracts",
    "rust:build": "cargo build --workspace",
    "rust:check": "npm run rust:fmt && npm run rust:lint && npm run rust:test && npm run rust:build"
  },
  "engines": {
    "node": ">=20"
  }
}
