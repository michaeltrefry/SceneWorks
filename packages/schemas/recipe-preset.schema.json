{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sceneworks.local/schemas/recipe-preset.schema.json",
  "title": "SceneWorks Recipe Preset Manifest",
  "description": "Recipe preset manifests may be rewritten by the SceneWorks API as generated JSONC with an API-managed header; inline comments are not preserved across API writes.",
  "type": "object",
  "required": ["schemaVersion", "presets"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "presets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "model", "workflow"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "enum": ["builtin", "global", "project"] },
          "archived": { "type": "boolean" },
          "order": {
            "type": "integer",
            "description": "Caller-owned display order. Values do not need to be unique; lists sort by scope (builtin, then global, then project), then order, then name."
          },
          "workflow": {
            "type": "string",
            "enum": ["text_to_image", "edit_image", "image_to_video", "text_to_video", "first_last_frame"]
          },
          "modes": { "type": "array", "items": { "type": "string" } },
          "model": { "type": "string", "minLength": 1 },
          "defaults": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "count": { "type": "integer", "minimum": 1 },
              "resolution": { "type": "string", "pattern": "^[0-9]+x[0-9]+$" },
              "negativePrompt": { "type": "string" }
            }
          },
          "prompt": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "prefix": { "type": "string" },
              "suffix": { "type": "string" }
            }
          },
          "loras": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["id"],
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
                "loraId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
                "sourceUrl": { "type": "string", "format": "uri" },
                "name": { "type": "string", "minLength": 1 },
                "displayName": { "type": "string", "minLength": 1 },
                "compatibility": {
                  "type": "object",
                  "additionalProperties": true
                },
                "weight": { "type": "number", "minimum": -2, "maximum": 2 }
              }
            }
          },
          "builtInLoras": {
            "description": "Deprecated legacy alias for loras. The API accepts this field on read and write migration paths, but API-managed manifest writes normalize it to loras.",
            "type": "array",
            "maxItems": 5,
            "items": {
              "oneOf": [
                { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
                {
                  "type": "object",
                  "required": ["id"],
                  "additionalProperties": false,
                  "properties": {
                    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
                    "loraId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
                    "sourceUrl": { "type": "string", "format": "uri" },
                    "name": { "type": "string", "minLength": 1 },
                    "displayName": { "type": "string", "minLength": 1 },
                    "compatibility": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "weight": { "type": "number", "minimum": -2, "maximum": 2 }
                  }
                }
              ]
            }
          },
          "appliedDefaults": {
            "description": "Read-only API metadata describing defaults synthesized while reading a legacy preset. These values are not persisted until the preset is saved through the API.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "notes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "ui": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
