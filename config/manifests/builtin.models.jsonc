      },
      "defaults": {
        // CFG baked: Heun at ~12 steps, guidance 1.0 (CFG off, negative prompt ignored).
        // 768² is the quality/speed sweet spot for Flash; use HD/Base for polished 1024² renders.
        "resolution": "768x768",
