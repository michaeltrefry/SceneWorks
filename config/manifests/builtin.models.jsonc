      },
      // macOS-only MLX backend (sc-1970). Optional sidecar venv at /opt/mlx-flux-venv
      // (apps/desktop/src/setup.rs provision_mlx_flux_venv); the worker auto-routes
      // FLUX schnell jobs here when the venv exists, falling back to the torch path
      // (FluxDiffusersAdapter) otherwise. sc-1969 spike: bf16 ~30% faster per step,
      // Q4/Q8 same speed with lower peak memory. quantize default Q8 (sweet spot —
      // matches bf16 speed on M-series, ~25% mem reduction, no visible quality drift).
      // minMemoryGb mirrors the Q4 peak (sc-1969: ~41.6 GB) so 64 GB Macs see this
      // tier; advanced.mlxQuantize=4 makes Q4 the runtime pick on smaller Macs.
      "mlx": {
