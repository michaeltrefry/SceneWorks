    {
      "id": "flux_dev",
      "name": "FLUX.1 [dev]",
      "family": "flux",
      "type": "image",
      "adapter": "flux_diffusers",
      // character_image: XLabs-AI/flux-ip-adapter (sc-2011 resemblance tier);
