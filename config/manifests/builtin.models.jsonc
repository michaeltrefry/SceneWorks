        // supersedes) → this turnkey snapshot. Source Wan-AI/Wan2.2-TI2V-5B is Apache-2.0;
        // converter "wan_ti2v_5b" emits bf16 (Q4/Q8 applied at load, not baked in).
        "minMemoryGb": 45,
